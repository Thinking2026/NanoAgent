{
  "task": {
    "name": "external_sorting"
  },
  "agent": {
    "max_tool_iterations": 10,
    "max_react_attempt_iterations": 30,
    "latency": {
      "thread_join_timeout_seconds": 1.0,
      "new_task_user_input_timeout_seconds": 60.0,
      "in_progress_wait_command_timeout_seconds": 5.0,
      "hint_input_timeout_seconds": 60.0,
      "agent_message_poll_timeout_seconds": 0.1,
      "user_progress_notice_interval_seconds": 2.0,
      "agent_user_message_wait_timeout_seconds": 2.0
    }
  },
  "llm": {
    "provider": "deepseek",
    "enable_provider_fallback": true,
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com/v1",
    "timeout": 120.0,
    "priority_chain": ["deepseek", "claude"],
    "context_trimming": {
      "enabled": true,
      "max_messages": 60
    },
    "retry": {
      "max_attempts": 1,
      "backoff_seconds": [1.0, 2.0, 4.0]
    },
    "provider_settings": {
      "claude": {
        "model": "claude-3-5-sonnet-latest",
        "base_url": "https://api.anthropic.com",
        "max_tokens": 1024,
        "anthropic_version": "2023-06-01"
      },
      "deepseek": {
        "model": "deepseek-chat",
        "base_url": "https://api.deepseek.com/v1"
      }
    }
  },
  "storage": {
    "backend": "file",
    "file": {
      "path": "runtime/agent_documents.json"
    },
    "sqlite": {
      "path": "runtime/agent_storage.db"
    },
    "chromadb": {
      "persist_directory": "",
      "collection_name": "agent_documents"
    }
  },
  "tools": {
    "package": null,
    "modules": [],
    "retry": {
      "max_attempts": 4,
      "backoff_seconds": [1.0, 2.0, 4.0]
    }
  },
  "tracing": {
    "enabled": true,
    "output_path": "runtime/traces.jsonl",
    "capture_payloads": true,
    "max_content_length": 2048
  }
}
